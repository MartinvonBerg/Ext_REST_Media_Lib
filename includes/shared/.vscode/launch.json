{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "attach",
            "name": "Attach to Chrome",
            "port": 9222,
            "webRoot": "${workspaceFolder}",
        },
        {
            "name": "Listen for XDebug",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "xdebugSettings": {
                "max_children": 200,
                "max_data": 1024,
                "max_depth": 5
            }
        },
        {
            "name": "Run PHPUnit (with Xdebug)",
            "type": "php",
            "request": "launch",
            "runtimeExecutable": "C:/PHP/php.exe",
            "program": "${workspaceFolder}/vendor/bin/phpunit",
            "args": [
                "${workspaceFolder}/tests/phpunit/testcases/MetadataExtractorTest.php"
                //"${workspaceFolder}/tests/phpunit/testcases/ExtractMetadataTest.php"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "XDEBUG_MODE": "debug",
                "XDEBUG_TRIGGER": "1"
            },
            "port": 9003,
            "stopOnEntry": false
        }
    ]
}